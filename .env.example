# ─── Database ───
DATABASE_URL="postgresql://user:pass@localhost:5432/ditrucks"

# ─── Auth ───
JWT_SECRET="cambia-este-secreto-en-produccion-minimo-32-chars"
COOKIE_NAME="ditrucks_session"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── CRM Webhook ───
WEBHOOK_CRM_SECRET="tu-secreto-para-el-webhook-crm"

# ─── Cloudflare R2 Storage ───
R2_ACCOUNT_ID="tu-account-id-de-cloudflare"
R2_ACCESS_KEY_ID="tu-access-key-id"
R2_SECRET_ACCESS_KEY="tu-secret-access-key"
R2_BUCKET_NAME="ditrucks-files"
R2_PUBLIC_URL="https://files.ditrucks.com.mx"
